# ============================================================
# WaziBot — Environment Variables
# Local dev: copy to .env
# Production: add to Render → Environment Variables
#
# NOTE ON PAYMENT SETTINGS:
#   Per-business EcoCash numbers and PayPal emails are configured
#   via the dashboard (Settings → Payment) and stored in Supabase.
#   The ENV vars below are PLATFORM-WIDE FALLBACKS only — useful for
#   single-business deployments or during initial setup.
# ============================================================

# ── CORE ─────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
VERIFY_TOKEN=your_whatsapp_webhook_verify_token

# ── SUPABASE ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── TOKEN ENCRYPTION ──────────────────────────────────────────
# Generate ONCE:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠  NEVER rotate this after tokens are stored — breaks all saved WhatsApp tokens.
FERNET_KEY=your_generated_fernet_key

# ── SUPER ADMIN ───────────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change_this_to_a_strong_password

# ─────────────────────────────────────────────────────────────
# PAYMENT METHOD FALLBACKS (platform-wide defaults)
# Each business overrides these via Settings → Payment in the dashboard.
# ─────────────────────────────────────────────────────────────

# ── ECOCASH (Zimbabwe manual payment) ─────────────────────────
# Platform-wide fallback EcoCash number.
# Businesses set their own via POST /me/payment-settings/ecocash
ECOCASH_NUMBER=
ECOCASH_NAME=

# ── PAYPAL (email-based — money goes straight to real account) ─
# Platform-wide fallback PayPal email.
# Businesses set their own via POST /me/payment-settings/paypal
#
# ⚠  This must be a REAL PayPal account email — not a test/sandbox address.
#    Customers will send money directly to this email via the PayPal app.
PAYPAL_EMAIL=

# ── PAYPAL API (optional — enables auto-checkout-link mode) ────
# If both PAYPAL_CLIENT_ID and PAYPAL_SECRET are set, WaziBot will
# automatically generate a PayPal checkout link instead of showing
# manual email instructions. Leave both blank for email-only mode.
#
# ⚠  ALWAYS use LIVE credentials — sandbox is not supported.
#    Get live credentials from: https://developer.paypal.com → My Apps & Credentials
#    Switch toggle from "Sandbox" to "Live" before copying credentials.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# URLs PayPal redirects to after payment (must be publicly reachable)
PAYPAL_RETURN_URL=https://wazibot-api-assistant.onrender.com/payments/paypal/success
PAYPAL_CANCEL_URL=https://wazibot-api-assistant.onrender.com/payments/paypal/cancel

# ── CASH ON DELIVERY ──────────────────────────────────────────
# Always available — no configuration needed.
